<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LOG.GG - 리그오브레전드 아이템 정보</title>
    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');
        :root {
            --primary-navy: #475569;
            --accent-blue: #3b82f6;
            --bg-soft: #f8fafc;
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --container-width: 1440px;
            --sidebar-width: 280px;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Pretendard', sans-serif;
            background-color: var(--bg-soft);
            color: #212529;
            width: var(--container-width);
            margin: 0 auto;
            line-height: 1.5;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--primary-navy);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 40px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 20px;
            font-weight: 600;
            color: #ecf0f5;
        }

        .user-nav {
            display: flex;
            gap: 20px;
            align-items: center;
            font-size: 14px;
            color: #ecf0f5;
        }

        .btn-logout {
            padding: 8px 18px;
            background: var(--bg-soft);
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
        }

        .main-layout {
            display: grid;
            grid-template-columns: var(--sidebar-width) 1fr var(--sidebar-width);
            gap: 30px;
            padding: 40px;
            min-height: 800px;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .top-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 38px;
            font-weight: 900;
            color: var(--primary-navy);
            letter-spacing: -2px;
            cursor: pointer;
        }

        .search-bar {
            background: white;
            border-radius: 15px;
            padding: 12px 20px;
            width: 380px;
            display: flex;
            align-items: center;
            box-shadow: var(--card-shadow);
            border: 1px solid transparent;
            transition: var(--transition);
        }

        .search-bar:focus-within {
            border-color: var(--accent-blue);
        }

        .search-bar input {
            border: none;
            outline: none;
            width: 100%;
            font-size: 15px;
            color: var(--primary-navy);
        }

        .item-card {
            background: white;
            border-radius: 24px;
            box-shadow: var(--card-shadow);
            padding: 30px;
            display: flex;
            gap: 40px;
        }

        .item-categories {
            display: flex;
            flex-direction: column;
            gap: 20px;
            width: 80px;
            align-items: center;
            border-right: 1px solid #e2e8f0;
            padding-right: 20px;
        }

        .category-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
        }

        .category-icon {
            width: 60px;
            height: 60px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            background: #f1f5f9;
        }

        .category-btn span {
            font-size: 13px;
            font-weight: 700;
            color: var(--primary-navy);
        }

        .item-table-container {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .item-table {
            width: 100%;
            border-collapse: collapse;
        }

        .item-table thead th {
            padding: 15px 10px;
            font-size: 14px;
            font-weight: 800;
            border-bottom: 2px solid #e2e8f0;
            color: var(--primary-navy);
            text-align: center;
        }

        .item-table thead th:not(:last-child) {
            border-right: 1px solid #f1f5f9;
        }

        .item-table tbody td {
            padding: 20px 10px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
            border-bottom: 1px solid #f1f5f9;
        }

        .icon { width: 70px; }
        .name-price { width: 80px; }

        .item-img-placeholder {
            width: 50px;
            height: 50px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            margin: 0 auto;
        }

        .pagination {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 30px;
        }

        .page-btn {
            padding: 5px 15px;
            border: 1px solid #cbd5e1;
            background: white;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            border-radius: 4px;
        }

        .side-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            margin-bottom: 25px;
        }

        .side-card h3 {
            font-size: 16px;
            font-weight: 800;
            margin: 0 0 18px 0;
            color: var(--primary-navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .side-card h3::before {
            content: '';
            width: 4px;
            height: 16px;
            background: var(--accent-blue);
            border-radius: 2px;
        }

        .menu-item {
            font-weight: 700;
            color: var(--primary-navy);
            padding: 10px 0;
            cursor: pointer;
        }

        .sub-item {
            padding: 8px 0 8px 20px;
            font-size: 14px;
            color: #64748b;
            cursor: pointer;
        }

        footer {
            padding: 60px 40px;
            text-align: center;
            font-size: 14px;
            color: #94a3b8;
            background: #f1f5f9;
            margin-top: 40px;
        }
    </style>
</head>
