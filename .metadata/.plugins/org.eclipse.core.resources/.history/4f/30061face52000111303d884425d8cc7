//룬 정보 js
$(document).ready(function () {
    const imgBase = "https://ddragon.leagueoflegends.com/cdn/img/perk-images/Styles/";
    const shardBase = "https://ddragon.leagueoflegends.com/cdn/img/perk-images/StatMods/";

    // 데이터 구조는 동일하게 유지
    const runeData = { /* ... 데이터 내용 생략 (기존과 동일) ... */ };
    const statShards = [ /* ... 데이터 내용 생략 (기존과 동일) ... */ ];

    let currentPrimary = "Precision";
    let currentSecondary = "Inspiration";

    // 1. 설명 업데이트 함수
    function updateDesc(name, desc) {
        const $nameEl = $('#desc-name, #detail-name');
        const $textEl = $('#desc-text, #detail-desc');
        $nameEl.text(name);
        $textEl.text(desc);
    }

    // 2. 핵심 빌드(Primary) 렌더링
    function renderPrimary() {
        const $container = $('#primary-slots-container');
        if (!$container.length) return;
        
        const data = runeData[currentPrimary];
        $container.empty();

        const $titleEl = $('#primary-path-name, #main-title');
        $titleEl.text(`핵심 빌드: ${data.name}`);

        // 핵심 룬 (Keystones)
        const $kRow = $('<div>').addClass('rune-row');
        $.each(data.keystones, function (i, r) {
            const $slot = $('<div>')
                .addClass(`slot keystone ${i === 0 ? 'active' : ''}`)
                .html(`<img src="${imgBase}${r.img}">`)
                .on('click', function () {
                    select($(this));
                    updateDesc(r.name, r.desc);
                });
            $kRow.append($slot);
        });
        $container.append($kRow);

        // 일반 룬 Rows
        $.each(data.rows, function (i, row) {
            const $rDiv = $('<div>').addClass('rune-row');
            $.each(row, function (j, r) {
                const $slot = $('<div>')
                    .addClass('slot')
                    .html(`<img src="${imgBase}${r.img}">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(r.name, r.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 3. 보조 빌드(Secondary) 렌더링
    function renderSecondary() {
        const $container = $('#secondary-slots-container');
        if (!$container.length) return;

        const data = runeData[currentSecondary];
        $container.empty();

        $.each(data.rows, function (i, row) {
            const $rDiv = $('<div>').addClass('rune-row');
            $.each(row, function (j, r) {
                const $slot = $('<div>')
                    .addClass('slot')
                    .html(`<img src="${imgBase}${r.img}">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(r.name, r.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 4. 능력치 파편(Shards) 렌더링
    function renderShards() {
        const $container = $('#stat-shards-container, #shard-slots');
        if (!$container.length) return;
        $container.empty();

        $.each(statShards, function (i, row) {
            const $rDiv = $('<div>').addClass('rune-row');
            $.each(row, function (j, sh) {
                const $slot = $('<div>')
                    .addClass('shard-slot')
                    .html(`<img src="${shardBase}${sh.img}" style="width:70%; opacity:0.8;">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(sh.name, sh.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 5. 보조 빌드 선택기 초기화
    function initSecondarySelector() {
        const $nav = $('#secondary-path-selector, #sub-path-list');
        if (!$nav.length) return;
        $nav.empty();

        Object.keys(runeData).forEach(key => {
            if (key === currentPrimary) return;

            const $img = $('<img>')
                .attr('src', `${imgBase}${runeData[key].img}`)
                .addClass(`sub-path-icon ${key === currentSecondary ? 'active' : ''}`)
                .css({ width: "30px", cursor: "pointer", margin: "0 5px" })
                .on('click', function () {
                    $nav.find('img').removeClass('active').css('opacity', '0.4');
                    $(this).addClass('active').css('opacity', '1');
                    currentSecondary = key;
                    renderSecondary();
                });
            
            // 초기 active 상태면 불투명도 조절
            if (key !== currentSecondary) $img.css('opacity', '0.4');
            
            $nav.append($img);
        });
    }

    // 6. 공통 선택 처리 함수
    function select($el) {
        $el.siblings().removeClass('active'); // 같은 행(row) 내의 다른 슬롯 비활성화
        $el.addClass('active');
    }

    // 7. 초기 이벤트 바인딩 및 실행
    const $pathIcons = $('.path-icon, .path-btn');
    $pathIcons.on('click', function () {
        $pathIcons.removeClass('active');
        $(this).addClass('active');
        
        currentPrimary = $(this).data('path') || $(this).data('id');
        renderPrimary();
        initSecondarySelector();
        // 보조 빌드가 메인과 겹치지 않게 로직 추가 가능
    });

    // 초기 렌더링 시작
    renderPrimary();
    initSecondarySelector();
    renderSecondary();
    renderShards();
});