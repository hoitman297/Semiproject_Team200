    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');

        :root {
            --primary-navy: #475569;
            --accent-blue: #3b82f6;
            --bg-soft: #f8fafc;
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            --container-width: 1440px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            margin: 0;
            font-family: 'Pretendard', sans-serif;
            background: var(--bg-soft);
            width: var(--container-width);
            margin: 0 auto;
        }

        /* 헤더 스타일 통일 */
        header {
            background: var(--primary-navy);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            height: 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .user-nav {
            display: flex;
            gap: 20px;
            align-items: center;
            font-size: 14px;
            color: #ecf0f5;
        }

        .btn-logout {
            padding: 8px 18px;
            background: var(--bg-soft);
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
        }

        .main-layout {
            display: grid;
            grid-template-columns: 280px 1fr 280px;
            gap: 30px;
            padding: 40px;
            min-height: 800px;
        }

        /* 좌측 사이드바 스타일 (아이템 페이지 스타일 적용) */
        .side-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
            margin-bottom: 25px;
        }

        .side-card h3 {
            font-size: 16px;
            font-weight: 800;
            margin: 0 0 18px 0;
            color: var(--primary-navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .side-card h3::before {
            content: '';
            width: 4px;
            height: 16px;
            background: var(--accent-blue);
            border-radius: 2px;
        }

        .menu-item {
            font-weight: 700;
            color: var(--primary-navy);
            padding: 10px 0;
            cursor: pointer;
        }

        .sub-item {
            padding: 8px 0 8px 20px;
            font-size: 14px;
            color: #64748b;
            cursor: pointer;
            transition: var(--transition);
        }

        .sub-item:hover {
            color: var(--accent-blue);
        }

        .sub-item.active {
            color: var(--accent-blue);
            font-weight: bold;
        }

        /* 룬 컨테이너 및 중앙 로고 */
        .logo {
            font-size: 38px;
            font-weight: 900;
            color: var(--primary-navy);
            margin-bottom: 20px;
            letter-spacing: -2px;
        }

        .rune-container {
            background: white;
            border-radius: 24px;
            box-shadow: var(--card-shadow);
            padding: 30px;
            display: flex;
            gap: 40px;
        }

        .rune-visual-section {
            flex: 1.3;
            background: #0a0a0c;
            border-radius: 16px;
            padding: 25px;
            color: white;
        }

        .path-selector {
            display: flex;
            justify-content: space-around;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 1px solid #333;
        }

        .path-icon {
            width: 45px;
            height: 45px;
            cursor: pointer;
            opacity: 0.3;
            filter: grayscale(1);
            transition: 0.3s;
        }

        .path-icon.active {
            opacity: 1;
            filter: grayscale(0);
            transform: scale(1.1);
        }

        .rune-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 30px;
        }

        .rune-col h5 {
            font-size: 13px;
            color: #d4af37;
            margin: 0 0 15px 0;
            text-transform: uppercase;
        }

        .rune-row {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            align-items: center;
        }

        .slot {
            width: 42px;
            height: 42px;
            border: 2px solid #444;
            border-radius: 50%;
            background: #111;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            transition: 0.2s;
        }

        .slot img {
            width: 80%;
            height: 80%;
            object-fit: contain;
        }

        .slot.active {
            border-color: #d4af37;
            box-shadow: 0 0 12px rgba(212, 175, 55, 0.5);
            background: #222;
        }

        .slot.keystone {
            width: 55px;
            height: 55px;
        }

        .secondary-path-nav {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }

        .sub-path-icon {
            width: 25px;
            height: 25px;
            cursor: pointer;
            opacity: 0.4;
        }

        .sub-path-icon.active {
            opacity: 1;
            filter: drop-shadow(0 0 5px #3b82f6);
        }

        .stat-shards {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #333;
        }

        .shard-slot {
            width: 28px;
            height: 28px;
            border: 1px solid #555;
            border-radius: 50%;
            background: #111;
            cursor: pointer;
        }

        .shard-slot.active {
            border-color: #fff;
            background: #444;
        }

        .rune-desc-section {
            flex: 0.7;
        }

        .desc-box {
            background: #f1f5f9;
            padding: 25px;
            border-radius: 16px;
            border-left: 6px solid var(--accent-blue);
            min-height: 200px;
        }

        #desc-name {
            font-size: 24px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 10px;
        }

        #desc-text {
            font-size: 15px;
            color: #475569;
            line-height: 1.6;
            white-space: pre-line;
        }

        /* 우측 사이드바 (아이템 페이지 스타일 적용) */
        .side-right .side-card {
            background: #cbd5e1;
            height: 300px;
            display: flex;
            flex-direction: column;
        }

        /* 푸터 스타일 통일 */
        footer {
            padding: 60px 40px;
            text-align: center;
            font-size: 14px;
            color: #94a3b8;
            background: #f1f5f9;
            margin-top: 40px;
        }
    </style>
</head>

