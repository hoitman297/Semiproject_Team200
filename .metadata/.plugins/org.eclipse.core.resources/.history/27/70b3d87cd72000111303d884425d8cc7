/* 공통 변수 및 초기화 */
@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');

:root {
    --primary-navy: #475569;
    --accent-blue: #3b82f6;
    --bg-soft: #f8fafc;
    --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --container-width: 1440px;
    --sidebar-width: 280px;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Pretendard', sans-serif;
    background-color: var(--bg-soft);
    color: #212529;
    width: var(--container-width);
    margin: 0 auto;
    line-height: 1.5;
}

a {
    text-decoration: none;
    color: inherit;
}

/* --- 헤더 및 내비게이션 --- */
header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--primary-navy);
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 40px;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 20px;
    font-weight: 600;
    cursor: pointer;
    color: #ecf0f5;
    padding: 10px 0;
}

.dropdown {
    position: relative;
    display: inline-block;
}

.dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: white;
    min-width: 160px;
    box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    overflow: hidden;
    z-index: 1;
    margin-top: 12px;
}

.dropdown-content a {
    color: #334155;
    padding: 12px 16px;
    display: block;
    font-size: 14px;
}

.dropdown-content a:hover {
    background-color: #f1f5f9;
    color: var(--accent-blue);
}

.dropdown.show .dropdown-content {
    display: block;
}

.user-nav {
    display: flex;
    gap: 20px;
    align-items: center;
    font-size: 14px;
    color: #ecf0f5;
}

.user-nav span {
    cursor: pointer;
    transition: var(--transition);
}

.user-nav span:hover {
    color: var(--accent-blue);
}

.btn-logout {
    padding: 8px 18px;
    background: var(--bg-soft);
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: var(--transition);
    color: #212529;
}

.btn-logout:hover {
    background: var(--accent-blue);
    color: white;
}



/* --- 푸터 --- */
footer {
    padding: 60px 40px;
    text-align: center;
    font-size: 14px;
    color: #94a3b8;
    background: #f1f5f9;
    margin-top: 40px;
}