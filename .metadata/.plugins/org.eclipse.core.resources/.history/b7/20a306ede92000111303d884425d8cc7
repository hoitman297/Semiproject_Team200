//영웅 정보 js
$('.tab-item, .d-tab').on('click', function () {
        // 1. 모든 .d-tab에서 active 클래스 제거 (가장 확실함)
        $('.d-tab').removeClass('active');
        // 2. 클릭한 요소에만 active 클래스 추가
        $(this).addClass('active');
});
        
        

//룬 정보 js
$(document).ready(function () {
    const imgBase = "https://ddragon.leagueoflegends.com/cdn/img/perk-images/Styles/";
    const shardBase = "https://ddragon.leagueoflegends.com/cdn/img/perk-images/StatMods/";

    // 데이터 구조는 동일하게 유지
    const runeData = { /* ... 기존 데이터 생략 ... */ };
    const statShards = [ /* ... 기존 데이터 생략 ... */ ];

    let currentPrimary = "Precision";
    let currentSecondary = "Inspiration";

    // 설명 업데이트 함수
    function updateDesc(name, desc) {
        $('#desc-name, #detail-name').text(name);
        $('#desc-text, #detail-desc').text(desc);
    }

    // 선택 효과 적용 함수 (공통)
    function select($el) {
        $el.siblings().removeClass('active');
        $el.addClass('active');
    }

    // 핵심 빌드 렌더링
    function renderPrimary() {
        const $container = $('#primary-slots-container');
        if (!$container.length) return;

        const data = runeData[currentPrimary];
        $container.empty();

        $('#primary-path-name, #main-title').text(`핵심 빌드: ${data.name}`);

        // 핵심 룬 (Keystones)
        const $kRow = $('<div class="rune-row"></div>');
        $.each(data.keystones, function (i, r) {
            const $slot = $(`<div class="slot keystone ${i === 0 ? 'active' : ''}"></div>`)
                .append(`<img src="${imgBase}${r.img}">`)
                .on('click', function () {
                    select($(this));
                    updateDesc(r.name, r.desc);
                });
            $kRow.append($slot);
        });
        $container.append($kRow);

        // 일반 룬 Rows
        $.each(data.rows, function (i, row) {
            const $rDiv = $('<div class="rune-row"></div>');
            $.each(row, function (j, r) {
                const $slot = $('<div class="slot"></div>')
                    .append(`<img src="${imgBase}${r.img}">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(r.name, r.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 보조 빌드 렌더링
    function renderSecondary() {
        const $container = $('#secondary-slots-container');
        if (!$container.length) return;

        const data = runeData[currentSecondary];
        $container.empty();

        $.each(data.rows, function (i, row) {
            const $rDiv = $('<div class="rune-row"></div>');
            $.each(row, function (j, r) {
                const $slot = $('<div class="slot"></div>')
                    .append(`<img src="${imgBase}${r.img}">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(r.name, r.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 능력치 파편 렌더링
    function renderShards() {
        const $container = $('#stat-shards-container, #shard-slots');
        if (!$container.length) return;

        $container.empty();
        $.each(statShards, function (i, row) {
            const $rDiv = $('<div class="rune-row"></div>');
            $.each(row, function (j, sh) {
                const $slot = $('<div class="shard-slot"></div>')
                    .append(`<img src="${shardBase}${sh.img}" style="width:70%; opacity:0.8;">`)
                    .on('click', function () {
                        select($(this));
                        updateDesc(sh.name, sh.desc);
                    });
                $rDiv.append($slot);
            });
            $container.append($rDiv);
        });
    }

    // 보조 빌드 선택기 초기화
    function initSecondarySelector() {
        const $nav = $('#secondary-path-selector, #sub-path-list');
        if (!$nav.length) return;

        $nav.empty();
        $.each(Object.keys(runeData), function (i, key) {
            if (key === currentPrimary) return;

            const $img = $('<img>')
                .attr('src', `${imgBase}${runeData[key].img}`)
                .addClass(`sub-path-icon ${key === currentSecondary ? 'active' : ''}`)
                .css({ width: '30px', cursor: 'pointer', margin: '0 5px' })
                .on('click', function () {
                    $nav.find('img').removeClass('active').css('opacity', '0.4');
                    $(this).addClass('active').css('opacity', '1');
                    currentSecondary = key;
                    renderSecondary();
                });

            // 초기 비활성 상태 투명도 설정
            if (key !== currentSecondary) $img.css('opacity', '0.4');
            $nav.append($img);
        });
    }

    // 메인 경로 아이콘 이벤트 바인딩
    $('.path-icon, .path-btn').on('click', function () {
        $('.path-icon, .path-btn').removeClass('active');
        $(this).addClass('active');

        currentPrimary = $(this).data('path') || $(this).data('id');
        renderPrimary();
        initSecondarySelector();
    });

    // 초기 실행
    renderPrimary();
    initSecondarySelector();
    renderSecondary();
    renderShards();
});