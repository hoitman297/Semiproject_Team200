$(document).ready(function () {
    // 1. 데이터 정의
    const mapAssets = {
        "에란겔 (Erangel)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Erangel_Main_Low_Res.png",
        "미라마 (Miramar)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Miramar_Main_Low_Res.png",
        "사녹 (Sanhok)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Sanhok_Main_Low_Res.png",
        "비켄디 (Vikendi)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Vikendi_Main_Low_Res.png",
        "테이고 (Taego)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Tiger_Main_Low_Res.png",
        "론도 (Rondo)": "https://raw.githubusercontent.com/pubg/api-assets/master/Assets/Maps/Neon_Main_Low_Res.png"
    };

    const markerData = {
        "기본 지도": [{ t: '30%', l: '45%', c: '#3b82f6' }, { t: '25%', l: '55%', c: '#3b82f6' }],
        "차량 스폰": [{ t: '40%', l: '50%', c: '#fbbf24' }, { t: '60%', l: '30%', c: '#fbbf24' }],
        "차고 위치": [{ t: '85%', l: '52%', c: '#06b6d4' }],
        "선박 위치": [{ t: '15%', l: '20%', c: '#a855f7' }],
        "비밀 방": [{ t: '12%', l: '75%', c: '#10b981' }]
    };

    // 2. Leaflet 초기화 (기존 #mapImg는 무시됨)
    const map = L.map('canvas', {
        crs: L.CRS.Simple, // 이미지 좌표계 사용
        minZoom: -2,
        maxZoom: 2,
        zoomControl: true
    });

    let currentImageOverlay = null;
    let markerLayerGroup = L.layerGroup().addTo(map);

    // 3. 지도 및 마커 업데이트 함수
    function updateMap(mapName) {
        const imageUrl = mapAssets[mapName];
        const bounds = [[0, 0], [1000, 1000]]; // 1000x1000 가상 좌표계

        if (currentImageOverlay) {
            map.removeLayer(currentImageOverlay);
        }

        currentImageOverlay = L.imageOverlay(imageUrl, bounds).addTo(map);
        map.fitBounds(bounds); // 지도가 이미지에 꽉 차게 설정

        renderMarkers();
    }

    function renderMarkers() {
        markerLayerGroup.clearLayers(); // 기존 마커 삭제

        $('.filter-item.active').each(function () {
            const type = $(this).text().trim();
            if (markerData[type]) {
                $.each(markerData[type], function (i, d) {
                    // % 단위를 1000 좌표계로 변환 (y축은 뒤집어야 함)
                    const y = 1000 - (parseFloat(d.t) * 10);
                    const x = parseFloat(d.l) * 10;

                    L.circleMarker([y, x], {
                        radius: 6,
                        fillColor: d.c,
                        color: "#fff",
                        weight: 2,
                        opacity: 1,
                        fillOpacity: 0.9,
                        className: 'pop-marker' // 애니메이션용 클래스
                    }).addTo(markerLayerGroup);
                });
            }
        });
    }

    // 4. 이벤트 바인딩
    $('.map-btn').on('click', function () {
        const mapName = $(this).text().trim();
        $(this).addClass('active').siblings().removeClass('active');
        
        // 지도 변경 시 필터 초기화(첫 번째만 활성)
        $('.filter-item').removeClass('active').first().addClass('active');
        updateMap(mapName);
    });

    $('.filter-item').on('click', function () {
        $(this).toggleClass('active'); // 다중 선택 가능하게 토글
        renderMarkers();
    });

    // 5. 초기 로드
    updateMap("에란겔 (Erangel)");
});