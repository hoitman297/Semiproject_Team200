<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title>LOG.GG - MAP GUIDE</title>
    <style>
        @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');

        :root {
            --primary-navy: #475569;
            --accent-blue: #3b82f6;
            --bg-soft: #f8fafc;
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --container-width: 1440px;
            --sidebar-width: 280px;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Pretendard', sans-serif;
            background-color: var(--bg-soft);
            color: #212529;
            width: var(--container-width);
            margin: 0 auto;
            line-height: 1.5;
            overflow-x: hidden;
        }

        /* 형이 준 헤더 스타일 적용 */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: var(--primary-navy);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 40px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 20px;
            font-weight: 600;
            color: #ecf0f5;
            cursor: pointer;
        }

        .user-nav {
            display: flex;
            gap: 20px;
            align-items: center;
            font-size: 14px;
            color: #ecf0f5;
        }

        .btn-logout {
            padding: 8px 18px;
            background: var(--bg-soft);
            border: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
        }

        .main-layout {
            display: grid;
            grid-template-columns: var(--sidebar-width) 1fr;
            gap: 30px;
            padding: 40px;
            min-height: 850px;
        }

        /* 왼쪽 사이드바 (전장 선택) */
        .side-left {
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .side-card {
            background: white;
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--card-shadow);
        }

        .side-card h3 {
            font-size: 16px;
            font-weight: 800;
            margin: 0 0 18px 0;
            color: var(--primary-navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .side-card h3::before {
            content: '';
            width: 4px;
            height: 16px;
            background: var(--accent-blue);
            border-radius: 2px;
        }

        .map-btn {
            width: 100%;
            text-align: left;
            padding: 12px 15px;
            border: none;
            background: none;
            font-weight: 700;
            color: #64748b;
            cursor: pointer;
            border-radius: 10px;
            transition: var(--transition);
            margin-bottom: 5px;
        }

        .map-btn:hover {
            background: #f1f5f9;
            color: var(--primary-navy);
        }

        .map-btn.active {
            background: var(--primary-navy);
            color: white;
        }

        /* 중앙 지도 영역 */
        .content-area {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .logo {
            font-size: 38px;
            font-weight: 900;
            color: var(--primary-navy);
            letter-spacing: -2px;
        }

        .map-container-card {
            background: white;
            border-radius: 24px;
            box-shadow: var(--card-shadow);
            padding: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* 필터바 */
        .filter-header {
            padding: 20px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: center;
            gap: 12px;
            background: #fff;
        }

        .filter-item {
            padding: 10px 22px;
            border-radius: 30px;
            background: #f1f5f9;
            font-size: 14px;
            font-weight: 700;
            color: #64748b;
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid transparent;
        }

        .filter-item.active {
            background: white;
            color: var(--accent-blue);
            border-color: var(--accent-blue);
            box-shadow: 0 4px 10px rgba(59, 130, 246, 0.1);
        }

        /* 지도 뷰포트 */
        .map-viewport {
            height: 700px;
            background: #ffffff;
            /* 어두운 배경이 지도 보기에 더 편합니다 */
            display: flex;
            justify-content: center;
            align-items: center;
            /* 수직/수평 중앙 정렬 */
            padding: 20px;
            overflow: hidden;
            /* 스크롤바 방지 */
        }

        /* [수정] 지도 캔버스: 이미지 크기에 딱 맞게 조절 */
        .map-canvas {
            position: relative;
            display: inline-block;
            /* 내용물(이미지) 크기에 딱 맞춰짐 */
            /* box-shadow: 0 0 50px rgba(0, 0, 0, 0.5); */
            max-height: 100%;
            /* 부모 높이를 넘지 않음 */
        }

        /* [수정] 지도 이미지: 규격 핵심 설정 */
        .map-image {
            display: block;
            max-width: 100%;
            /* 가로가 부모보다 크면 줄임 */
            max-height: 660px;
            /* 세로 높이 제한 (부모 700px 고려) */
            width: auto;
            height: auto;
            object-fit: contain;
            /* 비율 유지하며 박스 안에 맞춤 */
            border-radius: 8px;
        }

        /* 마커 위치 정확도 향상 */
        .marker {
            position: absolute;
            width: 9px;
            height: 9px;
            border: 1px solid white;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            /* 중심점 기준 정렬 */
            z-index: 10;
        }

        @keyframes pop {
            from {
                transform: translate(-50%, -50%) scale(0);
            }

            to {
                transform: translate(-50%, -50%) scale(1);
            }
        }

        .marker:hover {
            transform: translate(-50%, -50%) scale(1.4);
            z-index: 20;
            border-color: #fff;
        }

        footer {
            text-align: center;
            padding: 40px;
            color: #94a3b8;
            font-size: 14px;
        }
    </style>
</head>

<body>

    <header>
        <div class="header-left" onclick="location.href='main.html'">☰ 배틀그라운드 ▾</div>
        <div class="user-nav">
            <span>마이페이지</span>
            <span><b>USER01</b> 님</span>
            <button class="btn-logout">로그아웃</button>
        </div>
    </header>

    <div class="main-layout">
        <aside class="side-left">
            <div class="side-card">
                <h3>전장 선택</h3>
                <button class="map-btn active">에란겔 (Erangel)</button>
                <button class="map-btn">미라마 (Miramar)</button>
                <button class="map-btn">사녹 (Sanhok)</button>
                <button class="map-btn">비켄디 (Vikendi)</button>
                <button class="map-btn">테이고 (Taego)</button>
                <button class="map-btn">론도 (Rondo)</button>
            </div>
        </aside>

        <main class="content-area">
            <a href="../메인페이지.html">
                <div class="logo">LOG.GG</div>
            </a>

            <div class="map-container-card">
                <div class="filter-header">
                    <div class="filter-item active">기본 지도</div>
                    <div class="filter-item">차량 스폰</div>
                    <div class="filter-item">선박 위치</div>
                    <div class="filter-item">비밀 방/창고</div>
                    <div class="filter-item">글라이더</div>
                </div>

                <div class="map-viewport">
                    <div class="map-canvas" id="canvas">
                        <img id="mapImg" src="" alt="MAP" class="map-image">
                    </div>
                </div>
            </div>
        </main>
    </div>

    <footer>© 2026 LOG.GG 배틀그라운드 서비스. 모든 권리 보유.</footer>

    <script>
        const mapAssets = {
            "에란겔 (Erangel)": "../이미지/Erangel_Main_High_Res.png",
            "미라마 (Miramar)": "../이미지/Miramar_Main_High_Res.png",
            "사녹 (Sanhok)": "../이미지/Sanhok_Main_High_Res.png",
            "비켄디 (Vikendi)": "../이미지/Vikendi_Main_High_Res.png",
            "테이고 (Taego)": "../이미지/Taego_Main_High_Res.png",
            "론도 (Rondo)": "../이미지/Rondo_Main_High_Res.png"
        };

        const markerData = {
            "기본 지도": [{ t: '30%', l: '45%', c: '#3b82f6' }, { t: '25%', l: '55%', c: '#3b82f6' }],
            "차량 스폰": [{ t: '40%', l: '50%', c: '#fbbf24' }, { t: '60%', l: '30%', c: '#fbbf24' }],
            "선박 위치": [{ t: '85%', l: '52%', c: '#06b6d4' }],
            "비밀 방/창고": [{ t: '15%', l: '20%', c: '#a855f7' }],
            "글라이더": [{ t: '12%', l: '75%', c: '#10b981' }]
        };

        const mapImg = document.getElementById('mapImg');
        const canvas = document.getElementById('canvas');

        function updateMarkers(type) {
            canvas.querySelectorAll('.marker').forEach(m => m.remove());
            if (markerData[type]) {
                markerData[type].forEach(d => {
                    const m = document.createElement('div');
                    m.className = 'marker';
                    m.style.top = d.t; m.style.left = d.l; m.style.backgroundColor = d.c;
                    canvas.appendChild(m);
                });
            }
        }

        document.querySelectorAll('.map-btn').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.map-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                mapImg.src = mapAssets[btn.innerText.trim()];
                updateMarkers("기본 지도");
                document.querySelectorAll('.filter-item').forEach((f, i) => i === 0 ? f.classList.add('active') : f.classList.remove('active'));
            };
        });

        document.querySelectorAll('.filter-item').forEach(item => {
            item.onclick = () => {
                document.querySelectorAll('.filter-item').forEach(i => i.classList.remove('active'));
                item.classList.add('active');
                updateMarkers(item.innerText.trim());
            };
        });

        window.onload = () => {
            mapImg.src = mapAssets["에란겔 (Erangel)"];
            updateMarkers("기본 지도");
        };
    </script>
</body>

</html>