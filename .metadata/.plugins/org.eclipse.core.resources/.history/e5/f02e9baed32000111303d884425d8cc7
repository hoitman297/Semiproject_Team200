/* 공통 변수 및 초기화 */
@import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');

:root {
    --primary-navy: #475569;
    --accent-blue: #3b82f6;
    --bg-soft: #f8fafc;
    --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --container-width: 1440px;
    --sidebar-width: 280px;
}

body {
    margin: 0;
    padding: 0;
    font-family: 'Pretendard', sans-serif;
    background-color: var(--bg-soft);
    color: #212529;
    width: var(--container-width);
    margin: 0 auto;
    line-height: 1.5;
}

a {
    text-decoration: none;
    color: inherit;
}

/* --- 헤더 및 내비게이션 --- */
header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--primary-navy);
    padding: 15px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 40px;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 20px;
    font-weight: 600;
    cursor: pointer;
    color: #ecf0f5;
    padding: 10px 0;
}

.dropdown {
    position: relative;
    display: inline-block;
}

.dropdown-content {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: white;
    min-width: 160px;
    box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    overflow: hidden;
    z-index: 1;
    margin-top: 12px;
}

.dropdown-content a {
    color: #334155;
    padding: 12px 16px;
    display: block;
    font-size: 14px;
}

.dropdown-content a:hover {
    background-color: #f1f5f9;
    color: var(--accent-blue);
}

.dropdown.show .dropdown-content {
    display: block;
}

.user-nav {
    display: flex;
    gap: 20px;
    align-items: center;
    font-size: 14px;
    color: #ecf0f5;
}

.user-nav span {
    cursor: pointer;
    transition: var(--transition);
}

.user-nav span:hover {
    color: var(--accent-blue);
}

.btn-logout {
    padding: 8px 18px;
    background: var(--bg-soft);
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: var(--transition);
    color: #212529;
}

.btn-logout:hover {
    background: var(--accent-blue);
    color: white;
}

/* --- 사이드바 --- */
.side-card {
    background: white;
    padding: 24px;
    border-radius: 20px;
    box-shadow: var(--card-shadow);
    margin-bottom: 25px;
}

.side-card h3 {
    font-size: 16px;
    font-weight: 800;
    margin: 0 0 18px 0;
    color: var(--primary-navy);
    display: flex;
    align-items: center;
    gap: 10px;
}

.side-card h3::before {
    content: '';
    width: 4px;
    height: 16px;
    background: var(--accent-blue);
    border-radius: 2px;
}

.sidebar-right {
    background: #cbd5e1;
    border-radius: 20px;
    padding: 25px;
    height: fit-content;
    min-height: 400px;
}

.menu-item {
    font-weight: 700;
    color: var(--primary-navy);
    padding: 10px 0;
    cursor: pointer;
}

.sub-item {
    padding: 8px 0 8px 20px;
    font-size: 14px;
    color: #64748b;
    cursor: pointer;
    transition: var(--transition);
}

.sub-item:hover {
    color: var(--accent-blue);
}


/*박스 시뮬레이터 style*/
.content-area {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.logo {
    font-size: 32px;
    font-weight: 900;
    color: var(--primary-navy);
    letter-spacing: -1.5px;
    margin-bottom: 10px;
}

.sim-container {
    background: white;
    border-radius: 20px;
    padding: 30px;
    box-shadow: var(--card-shadow);
    border: 1px solid #e2e8f0;
}

.result-screen {
    width: 100%;
    height: 250px;
    background: #ffffff;
    border: 2px solid #f1f5f9;
    border-radius: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 28px;
    font-weight: 800;
    color: var(--primary-navy);
    margin-bottom: 30px;
    text-align: center;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
}

.control-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    margin-bottom: 30px;
}

.button-group {
    display: flex;
    gap: 10px;
}

.btn-pull {
    padding: 12px 30px;
    background: #6366f1;
    color: white;
    border: none;
    border-radius: 50px;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
}

.btn-pull:hover {
    background: #4f46e5;
    transform: translateY(-2px);
}

.btn-reset {
    background: none;
    border: 1px solid #e2e8f0;
    color: #94a3b8;
    padding: 5px 15px;
    border-radius: 20px;
    font-size: 13px;
    cursor: pointer;
}

.stats-panel {
    background: #f1f5f9;
    border-radius: 15px;
    padding: 20px;
}

.stats-title {
    font-size: 18px;
    font-weight: 800;
    color: var(--primary-navy);
    border-bottom: 2px solid #e2e8f0;
    padding-bottom: 10px;
    margin-bottom: 15px;
}

.stat-row {
    display: flex;
    justify-content: space-between;
    font-weight: 700;
    margin-bottom: 8px;
    font-size: 15px;
}

.grade-s {
    color: #f59e0b;
}

.grade-a {
    color: #8b5cf6;
}

/* layout */

.main-layout {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr var(--sidebar-width);
    gap: 30px;
    padding: 40px;
    min-height: 800px;
}

/* --- 푸터 --- */
footer {
    padding: 60px 40px;
    text-align: center;
    font-size: 14px;
    color: #94a3b8;
    background: #f1f5f9;
    margin-top: 40px;
}