<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>header</title>
	<link rel="stylesheet" href="${pageContext.request.contextPath}/resources/style/style.css">    
	<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
	<script src="${pageContext.request.contextPath}/script/script.js" defer></script>
</head>

<body>

    <header>
	<div class="dropdown" id="mainMenu">
        <%-- 부모 페이지에서 설정한 headerTitle 변수를 사용함 --%>
        <div class="header-left">☰ ${not empty headerTitle ? headerTitle : '메인페이지'} ▾</div>
        <div class="dropdown-content">
            <%-- 현재 페이지가 아닌 항목들만 노출되도록 조건부 처리 가능 --%>
            <c:if test="${headerTitle ne '배틀그라운드'}">
                <a href="${pageContext.request.contextPath}/배틀그라운드/배그메인페이지.jsp">배틀그라운드</a>
            </c:if>
            <c:if test="${headerTitle ne '리그 오브 레전드'}">
                <a href="${pageContext.request.contextPath}/롤/롤메인페이지.jsp">리그 오브 레전드</a>
            </c:if>
            <c:if test="${headerTitle ne '오버워치'}">
                <a href="${pageContext.request.contextPath}/오버워치/오버워치메인페이지.jsp">오버워치</a>
            </c:if>
            <a href="${pageContext.request.contextPath}/mainpage.jsp" style="border-top: 1px solid #eee;">메인페이지</a>
        </div>
    </div>

        <div class="user-nav">
            <span>마이페이지</span>
            <span>개인정보 수정</span>
            <span><b>USER01</b> 님</span>
            <button class="btn-logout">로그아웃</button>
        </div>
    </header>
</body>

</html>